TELEGRAM_BOT_TOKEN=your_bot_token_here
ALLOWED_USER_ID=your_telegram_user_id
CLAUDE_CLI_PATH=/path/to/claude

# Optional TTS. Unset TTS_URL = free edge-tts. Backend must be explicit.
# TTS_BACKEND: "openai" (default, POST /audio/speech) | "mimo" (POST /chat/completions)
TTS_URL=
TTS_BACKEND=openai
TTS_MODEL=tts-1
TTS_VOICE=nova
TTS_API_KEY=

# Optional: OpenAI-compatible multimodal endpoint for video understanding
# Example (mimo): VIDEO_API_URL=https://api.xiaomimimo.com/v1 + VIDEO_MODEL=mimo-v2-omni
VIDEO_API_URL=
VIDEO_MODEL=mimo-v2-omni
VIDEO_API_KEY=

# Optional: map button attached to tg_send_location. "amap"|"google"|"osm"|"none"
MAP_PROVIDER=amap

# Optional: whisper.cpp model path for voice transcription
WHISPER_MODEL=
